{
  "name": "@danielmuller/ts-base-dev-deps",
  "version": "0.0.0",
  "description": "Shared devDependencies for TypeScript projects (eslint, prettier, typescript, etc.)",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanielMuller/ts-base-dev-deps.git"
  },
  "bugs": {
    "url": "https://github.com/DanielMuller/ts-base-dev-deps/issues"
  },
  "homepage": "https://github.com/DanielMuller/ts-base-dev-deps#readme",
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "eslint": "10.3.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.4.1",
    "@tsconfig/node24": "24.0.4",
    "@types/jest": "30.0.0",
    "@types/node": "25.7.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-n": "18.0.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "17.0.4",
    "ts-jest": "29.4.9",
    "tsup": "8.5.1"
  },
  "scripts": {
    "postinstall": "node ./scripts/postinstall.mjs",
    "prepare": "husky"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,css,scss,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix --config eslint.config.mjs"
    ]
  }
}
